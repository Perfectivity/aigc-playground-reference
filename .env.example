# =============================================================================
# Tencent Media AIGC Playground — environment configuration (EXAMPLE)
#
# Copy this file to `.env` and fill in YOUR OWN values, then load it before
# starting the server, e.g.:
#
#     set -a; source .env; set +a
#     gunicorn -c gunicorn.conf.py app:app
#
# NOTHING in this repository ships with real credentials. Every value below is
# blank or a placeholder on purpose. You MUST bring your own Tencent Cloud
# account. See README.md for the cost warning.
# =============================================================================

# -----------------------------------------------------------------------------
# Tencent Cloud credentials (REQUIRED) — these are billed against YOUR account.
# Create a sub-account with least privilege; never commit the real values.
# -----------------------------------------------------------------------------
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=

# VOD sub-application id (0 = main application). Used by VOD AIGC (Music / 3D).
AIGC_SUB_APP_ID=0

# -----------------------------------------------------------------------------
# COS bucket for staging *reference images* (image-to-image / image-to-video).
# MPS fetches the image over the public internet, so this must be a COS bucket
# you own. The app hands MPS a pre-signed URL (1h), so the bucket itself does
# not need to be public.
#   AIGC_REF_BUCKET example: "your-bucket-1250000000"
#   AIGC_REF_REGION example: "ap-seoul"
# -----------------------------------------------------------------------------
AIGC_REF_BUCKET=
AIGC_REF_REGION=
AIGC_REF_PATH=aigc-playground/uploads

# -----------------------------------------------------------------------------
# COS bucket for *generated output* (images / videos / audio).
#   AIGC_COS_BUCKET example: "your-output-bucket-1250000000"
#   AIGC_COS_REGION example: "ap-guangzhou"
# -----------------------------------------------------------------------------
AIGC_COS_BUCKET=
AIGC_COS_REGION=
AIGC_COS_PATH=aigc-playground

# VOD AIGC region (Music / 3D generation).
AIGC_VOD_REGION=ap-seoul

# -----------------------------------------------------------------------------
# Public base URL of THIS server, if it sits behind a domain / reverse proxy.
# Leave blank for local development.  e.g. "https://your-host.example.com"
# -----------------------------------------------------------------------------
EXTERNAL_HOST=

# -----------------------------------------------------------------------------
# Optional web-search providers (only needed if you enable search-augmented
# chat). Leave blank to disable.
# -----------------------------------------------------------------------------
SERPER_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# -----------------------------------------------------------------------------
# Flask / gunicorn runtime
# -----------------------------------------------------------------------------
FLASK_DEBUG=0
FLASK_HOST=127.0.0.1
FLASK_PORT=5050
